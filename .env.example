# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=AQ.Ab8RN6L4571EbYwVXhljdk-Cxb_fb0e2wEsB--23ww9TNhyCbg

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# LLM provider for ai-core CLI: ollama | vertex
LLM_PROVIDER=vertex

# Vertex AI endpoint config (used when LLM_PROVIDER=vertex)
VERTEX_PROJECT_ID=seu-projeto-gcp
# Alternativa ao VERTEX_PROJECT_ID
GOOGLE_CLOUD_PROJECT=seu-projeto-gcp
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
# Preferencial para Termux (modo env)
VERTEX_API_KEY=
# Opcional quando VERTEX_AUTH_MODE=gcloud|auto
VERTEX_ACCESS_TOKEN=cole_seu_token_aqui
# env | gcloud | auto
VERTEX_AUTH_MODE=auto

# Optional tuning
VERTEX_TEMPERATURE=0.2
VERTEX_TOP_P=0.9
VERTEX_TOP_K=40
VERTEX_CANDIDATE_COUNT=1
VERTEX_MAX_OUTPUT_TOKENS=1024
VERTEX_TIMEOUT_SECONDS=90
VERTEX_MAX_RETRIES=3
VERTEX_RETRY_BASE_SECONDS=1.2
VERTEX_RETRY_MAX_SECONDS=8

# Optional behavior
VERTEX_SYSTEM_INSTRUCTION=Responda com foco em código limpo e performance.
VERTEX_SAFETY_HATE=BLOCK_MEDIUM_AND_ABOVE
VERTEX_SAFETY_HARASSMENT=BLOCK_MEDIUM_AND_ABOVE
VERTEX_SAFETY_SEXUAL=BLOCK_MEDIUM_AND_ABOVE
VERTEX_SAFETY_DANGEROUS=BLOCK_MEDIUM_AND_ABOVE

# Optional Ollama config (used when LLM_PROVIDER=ollama)
OLLAMA_MODEL=deepseek-coder:6.7b-instruct-q4_K_M
